---
tags: [database]
syntax: bash
---

# Show etcd cluster status
etcdctl endpoint status -w=table --cluster

# List nodes and cluster name
patronictl -c /etc/patroni/patroni.yml list

# Switch leader
patronictl -c /etc/patroni/patroni.yml switchover --leader <old_leader> --candidate <new_leader>

# Extremly switch leader 
patronictl -c /etc/patroni/patroni.yml failover --leader <old_leader> --candidate <new_leader>

# Re-init REPLICA
patronictl -c /etc/patroni/patroni.yml reinit CLUSTERNAME NODENAME
